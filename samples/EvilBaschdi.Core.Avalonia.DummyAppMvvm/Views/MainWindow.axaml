<local:FAAppWindow xmlns="https://github.com/avaloniaui"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                   xmlns:local="using:FluentAvalonia.UI.Windowing"
                   xmlns:viewModels="clr-namespace:EvilBaschdi.Core.Avalonia.DummyAppMvvm.ViewModels"
                   xmlns:models="clr-namespace:EvilBaschdi.Core.Avalonia.DummyAppMvvm.Models"
                   xmlns:controls="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
                   xmlns:evilBaschdi="clr-namespace:EvilBaschdi.Core.Avalonia.Controls;assembly=EvilBaschdi.Core.Avalonia"
                   x:Class="EvilBaschdi.Core.Avalonia.DummyAppMvvm.Views.MainWindow"
                   x:DataType="viewModels:MainWindowViewModel"
                   mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450" Width="800" Height="450"
                   Title="DummyAppMvvm">

    <Panel Name="RootPanel">

        <!-- ReSharper disable once Xaml.PathError -->
        <evilBaschdi:TitleBarControl Icon="/Assets/b.ico" Name="TitleBarControl" />

        <Panel Name="MainPanel" Margin="0,30,0,0">
            <Panel Name="ContentPanel" Margin="7">

                <DataGrid Name="TargetDataGrid" ItemsSource="{CompiledBinding DataGridCollectionViewCountries}" SelectedItem="{CompiledBinding Path=SelectedCountry}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Country" Binding="{CompiledBinding Name}" Width="6*" x:DataType="models:Country" />
                        <DataGridTextColumn Header="Region" Binding="{CompiledBinding Region}" Width="4*" x:DataType="models:Country" />
                        <DataGridTextColumn DisplayIndex="3" Header="Population" Binding="{CompiledBinding Population}" Width="3*" x:DataType="models:Country" />
                        <DataGridTextColumn DisplayIndex="2" Header="Area" Binding="{CompiledBinding Area}" Width="3*" x:DataType="models:Country" />
                        <DataGridTextColumn Header="GDP" Binding="{CompiledBinding Gdp}" Width="3*" x:DataType="models:Country" />

                        <DataGridTemplateColumn Header="Info" Width="100" IsReadOnly="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="models:Country">
                                    <!-- ReSharper disable Xaml.PossibleNullReferenceException -->
                                    <!-- ReSharper disable Xaml.BindingWithContextNotResolved -->
                                    <!-- ReSharper disable once Xaml.StyleClassNotFound -->
                                    <Button VerticalAlignment="Center" HorizontalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                            Width="90" Classes="accent" Name="ShowExtendedInformationButton"
                                            Command="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).ShowExtendedInformationCommand}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Show" Margin="0,0,5,0" />
                                            <controls:FASymbolIcon Symbol="Alert" FontSize="18" />
                                        </StackPanel>
                                    </Button>
                                    <!-- ReSharper restore Xaml.BindingWithContextNotResolved -->
                                    <!-- ReSharper restore Xaml.PossibleNullReferenceException -->
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>

            </Panel>
        </Panel>
    </Panel>
</local:FAAppWindow>