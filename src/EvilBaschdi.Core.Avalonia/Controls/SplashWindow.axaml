<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        x:Class="EvilBaschdi.Core.Avalonia.Controls.SplashWindow"
        d:DesignWidth="450" d:DesignHeight="350" Width="450" Height="350"
        WindowStartupLocation="CenterScreen"
        WindowDecorations="BorderOnly"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        CanResize="False"
        ShowInTaskbar="False"
        Topmost="True">
    <Border Name="SplashBorder" CornerRadius="12" BorderThickness="1" BorderBrush="#40FFFFFF">

        <Grid Margin="15" RowDefinitions="256,*">
            <!-- ReSharper disable once UnusedMember.Global -->
            <Image Grid.Row="0" x:Name="SplashImage" Stretch="Fill" HorizontalAlignment="Center"
                   VerticalAlignment="Center" Width="256" Height="256" />
            <TextBlock Grid.Row="1" x:Name="TaglineText" HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Grid>

    </Border>
</Window>