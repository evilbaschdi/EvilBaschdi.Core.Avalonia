    <PackageVersion Include="Avalonia.Desktop" Version="12.0.0-rc2" />
    <PackageVersion Include="AvaloniaUI.DiagnosticsSupport" Version="2.2.0-beta3" />
    <PackageVersion Include="Avalonia.Fonts.Inter" Version="12.0.0-rc2" />
    <PackageVersion Include="Avalonia.Headless" Version="12.0.0-rc2" />
    <PackageVersion Include="Avalonia.Themes.Fluent" Version="12.0.0-rc2" />
    <PackageVersion Include="Avalonia.Themes.Simple" Version="12.0.0-rc2" />
    <PackageVersion Include="EvilBaschdi.Core" Version="2026.3.30.19" />
    <PackageVersion Include="EvilBaschdi.Core.DependencyInjection" Version="2026.3.12.17" />
    <!--todo: reactivate once there are packages compatible with Avalonia 12-->
    <!--<PackageVersion Include="FluentAvaloniaUI" Version="2.5.1" />-->
    <PackageVersion Include="ReactiveUI" Version="23.2.1" />
    <PackageVersion Include="ReactiveUI.Avalonia" Version="11.4.12" />
    <PackageVersion Include="ReactiveUI.Avalonia.Microsoft.Extensions.DependencyInjection" Version="11.4.12" />
    <PackageVersion Include="TextMateSharp" Version="2.0.3" />
    <PackageVersion Include="TextMateSharp.Grammars" Version="2.0.3" />
  </ItemGroup>
  <!-- #endregion Project Libs -->
  <!-- #region Unit Test Libs -->
  <ItemGroup>
    <PackageVersion Include="EvilBaschdi.Testing" Version="2026.4.6.14" />
    <PackageVersion Include="coverlet.collector" Version="8.0.1" />
    <PackageVersion Include="FluentAssertions.Analyzers" Version="0.34.1" />
    <PackageVersion Include="Meziantou.FluentAssertionsAnalyzers" Version="1.0.22" />
