<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

        xmlns:viewModels="clr-namespace:EvilBaschdi.Core.Avalonia.DummyAppMvvm.ViewModels"
        xmlns:models="clr-namespace:EvilBaschdi.Core.Avalonia.DummyAppMvvm.Models"
        x:Class="EvilBaschdi.Core.Avalonia.DummyAppMvvm.Views.MainWindow"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450" Width="800" Height="450"
        x:DataType="viewModels:MainWindowViewModel"
        Icon="/Assets/b.ico"
        Title="EvilBaschdi.Avalonia.DummyAppMvvm">

    <Panel Name="RootPanel">

        <ExperimentalAcrylicBorder IsHitTestVisible="False" Name="AcrylicBorder">
            <ExperimentalAcrylicBorder.Material>
                <ExperimentalAcrylicMaterial TintColor="Black" TintOpacity="1" MaterialOpacity="0.9" />
            </ExperimentalAcrylicBorder.Material>
        </ExperimentalAcrylicBorder>

        <Panel Name="HeaderPanel" IsVisible="False">
            <Panel Margin="7">
                <Image Source="/Assets/b.ico" Width="20" Height="20" VerticalAlignment="Top" HorizontalAlignment="Left" />
            </Panel>
            <TextBlock Text="DummyApp" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,7,0,0" />
        </Panel>

        <Panel Name="MainPanel" Margin="0,0,0,0">
            <Panel Name="ContentPanel" Margin="0,0,0,0">

                <DataGrid Name="TargetDataGrid" ItemsSource="{Binding DataGridCollectionViewCountries}" SelectedItem="{Binding Path=SelectedCountry}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Country" Binding="{Binding Name}" Width="6*" x:DataType="models:Country" />
                        <DataGridTextColumn Header="Region" Binding="{Binding Region}" Width="4*" x:DataType="models:Country" />
                        <DataGridTextColumn DisplayIndex="3" Header="Population" Binding="{Binding Population}" Width="3*" x:DataType="models:Country" />
                        <DataGridTextColumn DisplayIndex="2" Header="Area" Binding="{Binding Area}" Width="3*" x:DataType="models:Country" />
                        <DataGridTextColumn Header="GDP" Binding="{Binding Gdp}" Width="3*" x:DataType="models:Country" />

                        <DataGridTemplateColumn Header="Info" Width="70" IsReadOnly="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="models:Country">
                                    <!-- ReSharper disable Xaml.PossibleNullReferenceException -->
                                    <!-- ReSharper disable Xaml.BindingWithContextNotResolved -->
                                    <!-- ReSharper disable once Xaml.StyleClassNotFound -->
                                    <Button VerticalAlignment="Center" HorizontalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                            Width="60" Classes="accent" Name="ShowExtendedInformationButton"
                                            Command="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).ShowExtendedInformationCommand}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Show" Margin="0,0,5,0" />
                                            <!--<controls:SymbolIcon Symbol="Alert" FontSize="18" />-->
                                        </StackPanel>
                                    </Button>
                                    <!-- ReSharper restore Xaml.BindingWithContextNotResolved -->
                                    <!-- ReSharper restore Xaml.PossibleNullReferenceException -->
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                    <DataGrid.Styles>
                        <Style Selector="DataGridColumnHeader">
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                        <Style Selector="DataGridRowGroupHeader">
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                    </DataGrid.Styles>
                </DataGrid>

            </Panel>
        </Panel>
    </Panel>
</Window>